# ══════════════════════════════════════════════════════════════
# L'Oro del Nilo — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# ══════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────
# Found in: https://app.supabase.com → Project Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon / public key — safe for browser use (read-only per RLS)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — server-side ONLY, full DB access — KEEP SECRET
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ── Cloudinary ──────────────────────────────────────────────
# Found in: https://cloudinary.com → Dashboard

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Upload preset (optional — for unsigned client-side uploads)
CLOUDINARY_UPLOAD_PRESET=loro-del-nilo-preset


# ── CORS ────────────────────────────────────────────────────
# Restrict to your frontend domain in production
# Use '*' only during development
ALLOWED_ORIGIN=https://lorodelnilo.it


# ── App ─────────────────────────────────────────────────────
NODE_ENV=development

# Base URL of this API (used for self-referencing links)
API_BASE_URL=http://localhost:3000


# ── Payments (Stripe) ───────────────────────────────────────
# Found in: https://dashboard.stripe.com → Developers → API keys

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret


# ── Email (optional — Resend / SendGrid) ────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@lorodelnilo.it
EMAIL_REPLY_TO=info@lorodelnilo.it


# ── Admin ───────────────────────────────────────────────────
# Simple static API key for admin-only routes
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your-secure-random-admin-key
